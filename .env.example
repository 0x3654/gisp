BOT_TOKEN={{ gisp_telegram_bot_token }}
CHAT_ID={{ gisp_telegram_chat_id }}
# Registry settings
REGISTRY_NODE_NAME={{ node_name }}

# PostgreSQL
POSTGRES_HOST=postgres_registry
POSTGRES_PORT={{ postgres_port }}
POSTGRES_USER={{ gisp_pg_user }}
POSTGRES_PASSWORD={{ gisp_pg_password }}
POSTGRES_DB={{ gisp_pg_db }}
PGDATA={{ pg_data }}
TZ={{ timezone }}
PG_AUTOPREWARM_INTERVAL={{ pg_autoprewarm_interval }}

# API service
REESTR_MIN_LIMIT={{ reestr_min_limit }}
REESTR_DEFAULT_LIMIT={{ reestr_default_limit }}
REESTR_MAX_LIMIT={{ reestr_max_limit }}
REESTR_MIN_OFFSET={{ reestr_min_offset }}
REESTR_DEFAULT_OFFSET={{ reestr_default_offset }}

# Semantic service
SEMANTIC_URL=http://semantic:{{ semantic_port }}/batch_semantic_normalize
SEMANTIC_CACHE_TTL_SECONDS={{ semantic_cache_ttl_seconds }}
SEMANTIC_FORCE_SEQSCAN={{ semantic_force_seqscan }}

# Import
FILES_DIR={{ files_dir }}
START_DATE={{ start_date }}
BASE_URL={{ base_url }}
LOG_DIR={{ log_dir }}
MAX_CSV_FILES={{ max_csv_files }}
MAX_LOG_FILES={{ max_log_files }}
AUTO_EMBED={{ auto_embed }}
STARTER_FORCE={{ starter_force }}

# Downloader
DOWNLOAD_METHOD={{ download_method }}
DOWNLOADER_SSH_HOST={{ downloader_ssh_host | default('') }}
DOWNLOADER_SSH_PORT={{ downloader_ssh_port | default('22') }}
DOWNLOADER_SSH_USER={{ downloader_ssh_user | default('') }}
DOWNLOADER_SSH_KEY_B64={{ gisp_downloader_ssh_key_b64 | default('') }}

# Docker compose infrastructure
POSTGRES_PORT={{ postgres_port }}
API_PORT={{ api_port }}
SEMANTIC_PORT={{ semantic_port }}
OPENWEBUI_PORT={{ openwebui_port }}
PG_SHM_SIZE={{ pg_shm_size }}
SEMANTIC_WORKERS={{ semantic_workers }}
STARTER_MAX_WAIT={{ starter_max_wait }}

# Embeddings worker
EMBEDDINGS_BATCH_SIZE={{ embeddings_batch_size }}
EMBEDDINGS_SHARD_INDEX={{ embeddings_shard_index }}
EMBEDDINGS_SHARD_COUNT={{ embeddings_shard_count }}

# Worker flags
FORCE={{ force }}
DRY_RUN={{ dry_run }}
SOURCE_FILES={{ source_files }}
EMBED_IDS={{ embed_ids }}
LIMIT={{ limit }}
EXTRA_EMBED_ARGS={{ extra_embed_args }}
SEMANTIC_URL_OVERRIDE={{ semantic_url_override }}
